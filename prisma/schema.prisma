generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id String @id @default(uuid())

  createdAt DateTime @default(now())
  updatedAt DateTime?
  
  title String
  slug String
  content String
  
  category String?
  published Boolean @default(true)
}

model UserActivity {
  id String @id @default(uuid())
  
  createdAt DateTime @default(now())
  
  data String
  country String
}